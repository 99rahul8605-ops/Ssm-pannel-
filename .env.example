# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_NAME=SMM Panel Bot
ADMIN_IDS=123456789,987654321     # Comma-separated Telegram user IDs
SUPPORT_USERNAME=yoursupport      # Without @

# ── SMM Panel API ─────────────────────────────────────────────────────────────
SMM_API_URL=https://smmpanelone.com/api/v2
SMM_API_KEY=your_smmpanelone_api_key

# ── UPI Manual Payment ────────────────────────────────────────────────────────
UPI_ID=yourname@paytm                # Tumhara UPI ID
UPI_NAME=Your Name                   # Account holder name

# ── Cashfree ──────────────────────────────────────────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=production           # production or sandbox

# ── Server (for webhook mode, optional) ──────────────────────────────────────
WEBHOOK_URL=https://yourdomain.com   # Leave empty for polling mode
PORT=8080
